{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "make-executable",
            "type": "shell",
            "command": "chmod +x *.sh",
            "problemMatcher": [],
            "presentation": {
                "echo": false,
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "./clean.sh",
            "problemMatcher": [],
            "dependsOn": [
                "make-executable"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            }
        },
        {
            "label": "unpack",
            "type": "shell",
            "command": "./unpack.sh",
            "problemMatcher": [],
            "dependsOn": [
                "make-executable"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false // Mantido false para ver o histórico do chmod se necessário
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "build",
            "type": "shell",
            "command": "./build.sh",
            "dependsOn": [
                "make-executable",
                "unpack"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}